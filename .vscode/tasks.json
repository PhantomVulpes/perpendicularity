{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Api/Api.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/Api/Api.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Api/Api.csproj"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-api",
            "command" : "npm run build-perpendicularity-api-client",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/Ui"
            }
        },
        {
            "label": "build-zinc-api-client",
            "command": "npm run build-zinc-api-client",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/Ui"
            }
        },
        {
            "label": "regenerate-all-api-clients",
            "dependsOn": ["sleep", "build-api", "build-zinc-api-client"],
            "dependsOrder": "sequence"
        },
        {
            "label": "sleep",
            "type": "shell",
            "command": "sleep 5",
            "presentation": {
                "reveal": "silent",
                "close": true
            }
        },
        {
            "label": "build-ui",
            "command": "npm run build",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}/Ui"
            },
            "problemMatcher": []
        }
    ]
}
