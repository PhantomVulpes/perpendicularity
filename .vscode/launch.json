{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/Api/bin/Debug/net9.0/Vulpes.Perpendicularity.Api.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Api",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "Build UI",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "build-ui",
      "args": ["--version"],
      "console": "integratedTerminal",
      "runtimeExecutable": "npm",
      "cwd": "${workspaceFolder}/Ui"
    },
    {
      "name": "Regenerate API Clients",
      "preLaunchTask": "regenerate-all-api-clients",
      "type": "node",
      "request": "launch",
      "args": ["--version"],
      "console": "integratedTerminal",
      "runtimeExecutable": "npm",
      "cwd": "${workspaceFolder}/Ui"
    }
  ],
  "compounds": [
    {
      "name": "Full Suite",
      "configurations": ["API", "Regenerate API Clients", "Build UI"],
      "stopAll": true
    }
  ]
}
